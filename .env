# Режим запуска:
#   default     — бесконечный сбор рыночных данных через WebSocket
#   train       — обучение XGBoost по накопленным xframes (xframes/{currency}/{version}/*.bin → model.ubj)
#   history_sim — историческая симуляция торговли по накопленным xframes с подсчётом P&L
#   real_sim    — живая (виртуальная) торговля по WS + HTTP-проверкой ордербука, 4 воркера (5m/15m × up/down)
STATUS=default